#!/usr/bin/exec-suid --environ=none -- /usr/local/bin/python -I

import os
import secrets
import sqlite3
import tempfile
import threading

from flask import Flask, abort, flash, redirect, render_template, request, session


class TemporaryDB:
    def __init__(self):
        self.db_file = tempfile.NamedTemporaryFile("x", suffix=".db")
        self.connection = sqlite3.connect(self.db_file.name, check_same_thread=False)
        self.connection.row_factory = sqlite3.Row
        self._lock = threading.Lock()

    def execute(self, sql, parameters=()):
        with self._lock:
            cursor = self.connection.cursor()
            result = cursor.execute(sql, parameters)
            self.connection.commit()
            return result


app = Flask(__name__)

flag = open("/flag").read().strip() if os.geteuid() == 0 else "pwn.college{fake_flag}"

db = TemporaryDB()
db.execute("CREATE TABLE users (username TEXT PRIMARY KEY, password TEXT NOT NULL)")
for username, password in [
    ("admin", secrets.token_hex(32)),
    ("guest", "password"),
    ("hacker", "1337"),
]:
    db.execute(
        "INSERT INTO users (username, password) VALUES (?, ?)",
        (username, password),
    )

db.execute(
    "CREATE TABLE posts ("
    "id INTEGER PRIMARY KEY, "
    "author TEXT NOT NULL, "
    "content TEXT NOT NULL, "
    "published INTEGER NOT NULL"
    ")"
)
for author, content, published in [
    ("admin", flag, 0),
    ("guest", "Loving the new pwnpost so far!", 1),
    ("hacker", "the dev finally locked down /post too. shame about /search though", 1),
]:
    db.execute(
        "INSERT INTO posts (author, content, published) VALUES (?, ?, ?)",
        (author, content, published),
    )


@app.route("/login", methods=["GET", "POST"])
def challenge_login():
    if session.get("username"):
        return redirect("/")

    if request.method == "POST":
        username = request.form.get("username", "")
        password = request.form.get("password", "")

        row = db.execute(
            "SELECT username FROM users WHERE username = ? AND password = ?",
            (username, password),
        ).fetchone()

        if not row:
            flash("Access denied: Invalid credentials")
            return redirect("/login")

        session["username"] = row["username"]
        return redirect("/")

    return render_template("login.html")


@app.route("/draft", methods=["POST"])
def challenge_draft():
    username = session.get("username")

    if not username:
        abort(403, "Log in first!")

    content = request.form.get("content", "")

    if not content:
        return redirect("/")

    db.execute(
        "INSERT INTO posts (content, author, published) VALUES (?, ?, ?)",
        (content, username, 1 if request.form.get("publish") else 0),
    )
    return redirect("/")


@app.route("/publish", methods=["POST"])
def challenge_publish():
    username = session.get("username")

    if not username:
        abort(403, "Log in first!")

    db.execute("UPDATE posts SET published = 1 WHERE author = ?", (username,))
    return redirect("/")


@app.route("/search", methods=["GET"])
def challenge_search():
    username = session.get("username")

    if not username:
        return redirect("/login")

    q = request.args.get("q", "")
    query = (
        "SELECT id, author, content FROM posts "
        f"WHERE content LIKE '%{q}%' AND published = 1"
    )

    results = None
    error = None
    try:
        results = db.execute(query).fetchall()
    except sqlite3.Error as exc:
        error = str(exc)

    return render_template(
        "search.html",
        username=username,
        q=q,
        results=results,
        error=error,
    )


@app.route("/", methods=["GET"])
def challenge_index():
    username = session.get("username")

    if not username:
        return redirect("/login")

    posts = db.execute("SELECT * FROM posts ORDER BY id").fetchall()
    return render_template("index.html", username=username, posts=posts)


@app.route("/logout")
def challenge_logout():
    session.clear()
    return redirect("/login")


app.secret_key = os.urandom(64)
app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
