#!/bin/bash

find -L /challenge -type f -exec chmod 0444 {} +
echo -e "10.0.13.37\tchallenge.internal" >> /etc/hosts
echo -e "10.0.13.38\tproxy.internal" >> /etc/hosts

# Network setup
ip addr add 10.0.13.37/32 dev eth0
ip addr add 10.0.13.38/32 dev eth0
ip route del local 10.0.13.37/32
ip route del local 10.0.13.38/32
ip route add local 10.0.13.37/32 dev lo src 127.0.0.1
ip route add local 10.0.13.38/32 dev lo src 127.0.0.1

iptables-legacy -A INPUT -p tcp -d 10.0.13.37 --dport 1024: -j REJECT
iptables-legacy -A INPUT -p tcp -d 10.0.13.38 --dport 1024: -j REJECT

iptables-legacy -A OUTPUT -p tcp -d 10.0.13.37 -m owner --uid-owner 1000 -j REJECT
iptables-legacy -A OUTPUT -p tcp -d 10.0.13.38 --dport 443 -m owner --uid-owner 1000 -m connlimit --connlimit-above 1023 -j REJECT

chmod 544 /challenge/server /challenge/watchdog
umask 066
mkdir -p /tmp/cache /var/log/nginx

/challenge/server &
until curl -fs https://challenge.internal/health >/dev/null; do sleep 0.1; done

nginx -c /challenge/nginx.conf
until curl -fsk https://proxy.internal/health >/dev/null; do sleep 0.1; done

/challenge/watchdog &
