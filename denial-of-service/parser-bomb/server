#!/usr/bin/env python

import os

from flask import Flask, request

app = Flask(__name__)
app.config["SERVER_NAME"] = "challenge.internal"
app.config["MAX_CONTENT_LENGTH"] = 16 * 1024  # 16 KB

MAX_EXPANDED = 1 * 1024 * 1024 * 1024  # 1 GB


def expand(node):
    if isinstance(node, dict) and "$repeat" in node:
        spec = node["$repeat"]
        if not isinstance(spec, list) or len(spec) != 2:
            return ""
        count, inner = spec
        if not isinstance(count, int) or count < 0:
            return ""
        inner_result = expand(inner)
        if len(inner_result) * count > MAX_EXPANDED:
            os._exit(137)
        return inner_result * count
    if isinstance(node, str):
        return node
    return ""


@app.get("/health")
def health():
    return "OK\n", 200


@app.post("/render")
def render():
    if not request.is_json:
        return {"error": "Invalid JSON"}, 400
    result = expand(request.json)
    return {"length": len(result)}


app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
