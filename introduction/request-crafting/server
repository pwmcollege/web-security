#!/usr/bin/env python

import urllib.parse

from flask import Flask, request

app = Flask(__name__)


@app.route("/", methods=["GET"])
def crlf():
    raw_qs = request.query_string.decode("latin-1")
    if not raw_qs.startswith("payload="):
        return "Missing payload.\n", 400

    payload = urllib.parse.unquote_to_bytes(raw_qs[len("payload=") :])
    if b"\r\n\r\n" not in payload:
        return "Missing CRLF separator.\n", 400

    head, body = payload.split(b"\r\n\r\n", 1)
    lines = head.split(b"\r\n")
    if len(lines) < 3:
        return "Not enough header lines.\n", 400

    if lines[0] != b"POST /submit HTTP/1.1":
        return "Wrong request line.\n", 400

    if lines[1] != b"Host: challenge.internal":
        return "Wrong host header.\n", 400

    if not lines[2].startswith(b"X-Sum: "):
        return "Missing X-Sum header.\n", 400

    try:
        sent_sum = int(lines[2][7:].decode("ascii"), 16)
    except ValueError:
        return "Invalid X-Sum format.\n", 400

    expected_sum = sum(body) & 0xFF
    if sent_sum != expected_sum:
        return "Wrong checksum.\n", 400

    if body != b"action=read&target=flag":
        return "Wrong payload.\n", 400

    with open("/flag", "r") as f:
        return f.read()


app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
