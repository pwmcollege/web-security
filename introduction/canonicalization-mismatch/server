#!/usr/bin/env python

import urllib.parse

from flask import Flask, request

app = Flask(__name__)


@app.route("/", methods=["GET"])
def twice():
    payload = request.args.get("payload")
    if not payload:
        return "Missing payload.\n", 400

    lowered = payload.lower()
    if "/flag" in lowered or "flag" in lowered:
        return "Blocked.\n", 403

    final = urllib.parse.unquote_to_bytes(payload)
    if final != b"read:/flag":
        return "Wrong payload.\n", 400

    with open("/flag", "r") as f:
        return f.read()


app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
