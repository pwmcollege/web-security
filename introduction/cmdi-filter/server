#!/usr/bin/exec-suid --environ=none --real -- /usr/local/bin/python -I

import subprocess

from flask import Flask, render_template, request

app = Flask(__name__)

BLOCKED = [";", "&", "|"]


@app.route("/", methods=["GET"])
def list_dir():
    path = request.args.get("path")
    if not path:
        return render_template("console.html", output=None)

    if any(token in path for token in BLOCKED):
        return render_template(
            "console.html", value=path, error="Nice try."
        )

    command = f"ls -la {path}"
    result = subprocess.run(command, shell=True, capture_output=True, text=True)
    return render_template(
        "console.html", value=path, output=result.stdout + result.stderr
    )


app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
