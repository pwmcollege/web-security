#!/usr/bin/exec-suid --environ=none -- /usr/local/bin/python -I

import os
import sqlite3
import tempfile
import threading

from flask import Flask, flash, redirect, render_template, request

app = Flask(__name__)


class TemporaryDB:
    def __init__(self):
        self.db_file = tempfile.NamedTemporaryFile("x", suffix=".db")
        self.connection = sqlite3.connect(self.db_file.name, check_same_thread=False)
        self.connection.row_factory = sqlite3.Row
        self._lock = threading.Lock()

    def execute(self, sql, parameters=()):
        with self._lock:
            cursor = self.connection.cursor()
            result = cursor.execute(sql, parameters)
            self.connection.commit()
            return result


flag = open("/flag").read().strip() if os.geteuid() == 0 else "pwn.college{fake_flag}"

db = TemporaryDB()
db.execute(
    """CREATE TABLE posts AS SELECT ? AS content, "admin" AS author, FALSE AS published""",
    [flag],
)
db.execute(
    """CREATE TABLE users AS SELECT "admin" AS username, ? AS password""",
    [os.urandom(16).hex()],
)
db.execute("""INSERT INTO users SELECT "guest" AS username, "password" AS password""")
db.execute("""INSERT INTO users SELECT "hacker" AS username, "1337" AS password""")


def current_user():
    return request.args.get("session_user")


def home(username):
    return redirect(f"/?session_user={username}")


@app.route("/login", methods=["GET", "POST"])
def challenge_login():
    if request.method == "POST":
        username = request.form.get("username")
        password = request.form.get("password")

        if not username or not password:
            flash("Identity credentials required")
            return redirect("/login")

        user = db.execute(
            "SELECT username FROM users WHERE username = ? AND password = ?",
            (username, password),
        ).fetchone()

        if not user:
            flash("Access denied: Invalid credentials")
            return redirect("/login")

        return home(user["username"])

    return render_template("login.html", hide_chrome=True)


@app.route("/register", methods=["GET", "POST"])
def challenge_register():
    if request.method == "POST":
        username = request.form.get("username")
        password = request.form.get("password")

        if not username or not password:
            flash("Identity credentials required")
            return redirect("/register")

        count = db.execute("SELECT COUNT(*) AS n FROM users").fetchone()["n"]
        if count >= 3:
            flash("Account limit reached")
            return redirect("/register")

        db.execute(
            "INSERT INTO users (username, password) VALUES (?, ?)",
            (username, password),
        )
        flash("Account created! Please log in.")
        return redirect("/login")

    return render_template("register.html", hide_chrome=True)


@app.route("/draft", methods=["POST"])
def challenge_draft():
    username = current_user()
    if not username:
        return redirect("/login")

    content = request.form.get("content", "")
    db.execute(
        "INSERT INTO posts (content, author, published) VALUES (?, ?, ?)",
        (content, username, bool(request.form.get("publish"))),
    )
    return home(username)


@app.route("/publish", methods=["POST"])
def challenge_publish():
    username = current_user()
    if not username:
        return redirect("/login")

    post_id = request.form.get("post_id")
    if post_id:
        db.execute(
            "UPDATE posts SET published = TRUE WHERE author = ? AND rowid = ?",
            [username, post_id],
        )
    else:
        db.execute("UPDATE posts SET published = TRUE WHERE author = ?", [username])
    return home(username)


@app.route("/", methods=["GET"])
def challenge_get():
    username = current_user()
    if not username:
        return redirect("/login")

    posts = db.execute("SELECT rowid, * FROM posts").fetchall()
    return render_template(
        "index.html", username=username, posts=posts, q=f"?session_user={username}"
    )


@app.route("/logout")
def challenge_logout():
    return redirect("/login")


app.secret_key = os.urandom(64)
app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
