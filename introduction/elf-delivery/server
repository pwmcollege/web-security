#!/usr/bin/env python

import base64
import binascii
import os
import subprocess

from flask import Flask, request

app = Flask(__name__)


@app.route("/", methods=["GET"])
def run_elf():
    encoded = request.args.get("elf", "")
    if not encoded:
        return "Missing elf query parameter.\n", 400

    try:
        padding = "=" * (-len(encoded) % 4)
        blob = base64.urlsafe_b64decode(encoded + padding)
    except (ValueError, binascii.Error):
        return "Invalid base64 payload.\n", 400

    if not blob.startswith(b"\x7fELF"):
        return "Not an ELF binary.\n", 400

    if len(blob) > 1024 * 1024:
        return "Binary too large.\n", 400

    if not hasattr(os, "memfd_create"):
        return "memfd_create is unavailable.\n", 500

    fd = os.memfd_create("fp-bin", os.MFD_CLOEXEC)
    try:
        os.write(fd, blob)
        os.fchmod(fd, 0o700)
        path = f"/proc/self/fd/{fd}"

        result = subprocess.run(
            [path],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=2,
            check=False,
            pass_fds=(fd,),
        )

        if result.returncode != 0:
            return "Binary exited with failure.\n", 400

        return "Binary executed.\n", 200
    finally:
        try:
            os.close(fd)
        except OSError:
            pass


app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
