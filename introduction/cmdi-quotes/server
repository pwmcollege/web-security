#!/usr/bin/env python

import subprocess

from flask import Flask, request

app = Flask(__name__)

USAGE = "Directory listing tool. Usage: /?path=<dir>\n"


@app.route("/", methods=["GET"])
def list_dir():
    path = request.args.get("path")
    if not path:
        return USAGE, 400

    # Filtering characters was a losing game. Instead, wrap the whole argument
    # in quotes so the shell treats it as a single, literal string.
    command = f"ls -la '{path}'"
    result = subprocess.run(
        command, shell=True, capture_output=True, text=True
    )
    return result.stdout + result.stderr


app.config["SERVER_NAME"] = "challenge.internal"
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
