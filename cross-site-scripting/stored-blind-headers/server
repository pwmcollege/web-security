#!/usr/bin/exec-suid --environ=none -- /usr/local/bin/python -I

import os
import sqlite3
import tempfile
import threading

from flask import (
    Flask,
    abort,
    flash,
    make_response,
    redirect,
    render_template,
    request,
    session,
)
from werkzeug.security import check_password_hash, generate_password_hash

app = Flask(__name__)


class TemporaryDB:
    def __init__(self):
        self.db_file = tempfile.NamedTemporaryFile("x", suffix=".db")
        self.connection = sqlite3.connect(self.db_file.name, check_same_thread=False)
        self.connection.row_factory = sqlite3.Row
        self._lock = threading.Lock()

    def execute(self, sql, parameters=()):
        with self._lock:
            cursor = self.connection.cursor()
            result = cursor.execute(sql, parameters)
            self.connection.commit()
            return result


flag = open("/flag").read().strip() if os.geteuid() == 0 else "pwn.college{fake_flag}"

db = TemporaryDB()
db.execute("""CREATE TABLE posts (content TEXT, author TEXT, published BOOLEAN)""")
db.execute(
    """CREATE TABLE users AS SELECT "admin" AS username, ? as password""",
    [generate_password_hash(flag)],
)
db.execute(
    """INSERT INTO users SELECT "guest" as username, ? as password""",
    [generate_password_hash("password")],
)
db.execute(
    """INSERT INTO users SELECT "hacker" as username, ? as password""",
    [generate_password_hash("1337")],
)
db.execute(
    """CREATE TABLE reports (id INTEGER PRIMARY KEY AUTOINCREMENT, content TEXT, author TEXT)"""
)


@app.route("/login", methods=["GET", "POST"])
def challenge_login():
    if session.get("username"):
        return redirect("/")

    if request.method == "POST":
        username = request.form.get("username")
        password = request.form.get("password")

        if not username or not password:
            flash("Identity credentials required")
            return redirect("/login")

        user = db.execute(
            "SELECT * FROM users WHERE username = ?",
            (username,),
        ).fetchone()

        if not user or not check_password_hash(user["password"], password):
            flash("Access denied: Invalid credentials")
            return redirect("/login")

        session["username"] = username
        return redirect("/")

    return render_template("login.html")


@app.route("/register", methods=["GET", "POST"])
def challenge_register():
    if session.get("username"):
        return redirect("/")

    if request.method == "POST":
        username = request.form.get("username")
        password = request.form.get("password")

        if not username or not password:
            flash("Identity credentials required")
            return redirect("/register")

        user = db.execute(
            "SELECT * FROM users WHERE username = ?",
            (username,),
        ).fetchone()

        if user:
            flash("Username already taken")
            return redirect("/register")

        db.execute(
            "INSERT INTO users (username, password) VALUES (?, ?)",
            (username, generate_password_hash(password)),
        )

        flash("Account created! Please log in.")
        return redirect("/login")

    return render_template("register.html")


@app.route("/draft", methods=["POST"])
def challenge_draft():
    username = session.get("username", None)
    if not username:
        abort(403, "Log in first!")

    if username == "admin":
        abort(400, "pwnpost doesn't support admin posting")

    content = request.form.get("content", "")
    db.execute(
        "INSERT INTO posts (content, author, published) VALUES (?, ?, ?)",
        (content, username, bool(request.form.get("publish"))),
    )
    return redirect("/")


@app.route("/publish", methods=["POST"])
def challenge_publish():
    username = session.get("username", None)
    if not username:
        abort(403, "Log in first!")

    if username == "admin":
        abort(400, "pwnpost doesn't support admin posting")

    db.execute("UPDATE posts SET published = TRUE WHERE author = ?", [username])
    return redirect("/")


@app.route("/report", methods=["GET", "POST"])
def challenge_report():
    username = session.get("username")
    if not username or username == "admin":
        abort(403)

    if request.method == "POST":
        content = request.form.get("content", "")
        db.execute(
            "INSERT INTO reports (content, author) VALUES (?, ?)",
            (content, username),
        )
        flash("Report submitted!")
        return redirect("/report")

    return render_template("report.html", username=username)


@app.route("/reports")
def challenge_reports():
    username = session.get("username")
    if username != "admin":
        abort(403)

    reports = db.execute("SELECT * FROM reports").fetchall()
    return render_template("reports.html", username=username, reports=reports)


@app.route("/flag")
def challenge_flag():
    username = session.get("username")
    if username != "admin":
        abort(403)

    response = make_response("", 204)
    response.headers["X-Flag"] = flag
    return response


@app.route("/", methods=["GET"])
def challenge_get():
    username = session.get("username")
    if not username:
        return redirect("/login")

    posts = db.execute("SELECT * FROM posts").fetchall()
    return render_template("index.html", username=username, posts=posts)


@app.route("/logout")
def challenge_logout():
    session.clear()
    return redirect("/")


app.secret_key = os.urandom(64)
app.config["SERVER_NAME"] = "challenge.internal"
app.config["SESSION_COOKIE_HTTPONLY"] = True
app.run(
    "challenge.internal",
    443,
    ssl_context=(
        "/etc/ssl/certs/internal.cert.pem",
        "/etc/ssl/private/internal.key.pem",
    ),
)
