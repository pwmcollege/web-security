#!/usr/bin/exec-suid --environ=none -- /usr/local/bin/python -I

import os
import re

from bs4 import BeautifulSoup, NavigableString, Tag
from flask import Flask, render_template, request

app = Flask(__name__)

ALLOWLIST = [
    "script",
]

BLOCKLIST = [
    (r"fetch", re.IGNORECASE),
    (r"xmlhttprequest", re.IGNORECASE),
    (r"sendbeacon", re.IGNORECASE),
    (r"location", re.IGNORECASE),
    (r"open\s*\(", re.IGNORECASE),
    (r"assign\s*\(", re.IGNORECASE),
    (r"replace\s*\(", re.IGNORECASE),
    (r"pushstate", re.IGNORECASE),
    (r"replacestate", re.IGNORECASE),
    (r"submit", re.IGNORECASE),
    (r"requestsubmit", re.IGNORECASE),
    (r"click", re.IGNORECASE),
    (r"createelement(?:ns)?", re.IGNORECASE),
    (r"(?:adopt|import|clone)node", re.IGNORECASE),
    (r"append(?:child)?", re.IGNORECASE),
    (r"prepend", re.IGNORECASE),
    (r"before", re.IGNORECASE),
    (r"after", re.IGNORECASE),
    (r"insertbefore", re.IGNORECASE),
    (r"insertadjacent(?:html|text|element)", re.IGNORECASE),
    (r"replace(?:children|child|with)", re.IGNORECASE),
    (r"remove(?:child)?", re.IGNORECASE),
    (r"innerhtml", re.IGNORECASE),
    (r"outerhtml", re.IGNORECASE),
    (r"(?:inner|outer)(?:text|html)", re.IGNORECASE),
    (r"textcontent", re.IGNORECASE),
    (r"setattribute(?:ns)?", re.IGNORECASE),
    (r"removeattribute(?:ns)?", re.IGNORECASE),
    (r"toggleattribute", re.IGNORECASE),
    (r"queryselector(?:all)?", re.IGNORECASE),
    (r"getelement(?:sbytagname|sbyclassname|byid|sbyname)", re.IGNORECASE),
    (r"write", re.IGNORECASE),
    (r"writeln", re.IGNORECASE),
    (r"href", re.IGNORECASE),
    (r"src", re.IGNORECASE),
    (r"action", re.IGNORECASE),
    (r"formaction", re.IGNORECASE),
    (r"srcdoc", re.IGNORECASE),
    (r"cookiestore", re.IGNORECASE),
    (r"cookie", re.IGNORECASE),
    (r"(?:local|session)storage", re.IGNORECASE),
    (r"formdata", re.IGNORECASE),
    (r"url(?:searchparams)?", re.IGNORECASE),
    (r"request", re.IGNORECASE),
    (r"headers", re.IGNORECASE),
    (r"response", re.IGNORECASE),
    (r"media", re.IGNORECASE),
    (r"image", re.IGNORECASE),
    (r"audio", re.IGNORECASE),
    (r"video", re.IGNORECASE),
    (r"track", re.IGNORECASE),
    (r"source", re.IGNORECASE),
    (r"bitmap", re.IGNORECASE),
    (r"canvas", re.IGNORECASE),
    (r"blob", re.IGNORECASE),
    (r"file", re.IGNORECASE),
    (r"navigator", re.IGNORECASE),
    (r"postmessage", re.IGNORECASE),
    (r"document", re.IGNORECASE),
    (r"window", re.IGNORECASE),
    (r"globalthis", re.IGNORECASE),
    (r"global", re.IGNORECASE),
    (r"self", re.IGNORECASE),
    (r"this", re.IGNORECASE),
    (r"top", re.IGNORECASE),
