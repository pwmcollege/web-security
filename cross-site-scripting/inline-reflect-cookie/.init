#!/bin/bash

find -L /challenge -type f -exec chmod 0444 {} +
echo -e "10.0.13.37\tchallenge.internal" >> /etc/hosts
echo -e "10.0.13.36\cdn.internal" >> /etc/hosts

# Network setup
ip addr add 10.0.13.36/32 dev eth0
ip addr add 10.0.13.37/32 dev eth0
ip route del local 10.0.13.36/32
ip route del local 10.0.13.37/32
ip route add local 10.0.13.36/32 dev lo src 127.0.0.1
ip route add local 10.0.13.37/32 dev lo src 127.0.0.1

# Reject packets sent to 10.0.13.37 at non-privileged ports
iptables-legacy -A OUTPUT -d 10.0.13.36 -m owner ! --uid-owner 0 -j DROP
iptables-legacy -A INPUT -p tcp -d 10.0.13.36 --dport 1024: -j REJECT
iptables-legacy -A INPUT -p tcp -d 10.0.13.37 --dport 1024: -j REJECT

/opt/cdn/server &
chmod 4555 /challenge/server
chmod 4555 /challenge/victim
